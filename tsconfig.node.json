{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "outDir": "dist/main"
  },
  "include": ["src/main/**/*", "src/shared/**/*", "src/vendor/**/*", "electron.vite.config.ts"]
}
