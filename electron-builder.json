{
  "appId": "com.claude.desktop",
  "productName": "Claude Code Desktop",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "resources/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "resources/icons/icon.ico"
